@model VitrineSemiJoias.ViewModels.LoginViewModel

@{
    Layout = null; 
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Acessar Sistema | Vitrine SemiJoias</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/tailwind.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body {
            background-color: #f8f9fa;
            font-family: system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }
        .tracking-wider { 
            letter-spacing: 1.5px; 
            font-size: 0.75rem; 
        }
        .input-group .form-control:focus { 
            z-index: 3; 
        }
    </style>
</head>
<body>

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="col-sm-10 col-md-6 col-lg-4">
            
            <div class="text-center mb-4">
                <h1 class="h3 fw-bold text-dark font-monospace mb-1">Vitrine</h1>
                <p class="text-muted small text-uppercase tracking-wider">Painel Administrativo</p>
            </div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden bg-white">
                <div class="card-body p-4 p-sm-5">
                    
                    <h2 class="fs-5 fw-bold text-center text-dark mb-4">Acessar Sistema</h2>

                    <form asp-action="Login" method="post">
                        
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 small mb-3 border-0 rounded-3"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold text-secondary small">E-mail comercial</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-muted border-end-0 rounded-start-3" style="font-size: 0.9rem;">
                                    <i class="bi bi-envelope"></i>
                                </span>
                                <input asp-for="Email" class="form-control border-start-0 rounded-end-3 py-2" placeholder="seu@email.com" autocomplete="email" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-semibold text-secondary small">Senha de acesso</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-muted border-end-0 rounded-start-3" style="font-size: 0.9rem;">
                                    <i class="bi bi-lock"></i>
                                </span>
                                <input asp-for="Password" type="password" class="form-control border-start-0 rounded-end-3 py-2" placeholder="••••••••" autocomplete="current-password" />
                            </div>
                            <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="IsPersistent" class="form-check-input" />
                            <label asp-for="IsPersistent" class="form-check-label text-secondary small">Lembrar de mim</label>
                        </div>

                        <button type="submit" class="btn btn-dark w-100 py-2.5 rounded-3 fw-semibold shadow-sm mb-2">
                            <i class="bi bi-box-arrow-in-right me-2"></i> Entrar
                        </button>
                        
                    </form>
                </div>
            </div>

            <div class="text-center mt-4">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted small">
                    <i class="bi bi-arrow-left me-1"></i> Voltar para a loja vitrine
                </a>
            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>