@using VitrineSemiJoias.Enums
@using VitrineSemiJoias.ViewModels
@model IEnumerable<ProductViewModel>

@{
    ViewData["Title"] = "Vitrine de Produtos";
}

<div class="container-fluid py-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold" style="color: #343a40;">Nossos Produtos</h1>
        <p class="lead text-muted">Conheça nossa coleção exclusiva de joias e acessórios</p>
    </div>
<div class="mb-5">
    <form asp-controller="Products" asp-action="Category" method="get" class="d-flex align-items-center gap-2">
        <label for="category" class="fw-bold">Filtrar por Categoria:</label>
        <select name="category"
                id="category"
                class="form-select w-auto"
                onchange="this.form.submit()"
                asp-items="Html.GetEnumSelectList<CategoryEnum>()">
            <option value="">Todas as Categorias</option>
        </select>
    </form>
</div>
    @if (Model?.Any() == true)
    {
        <div class="row g-4">
            @foreach (var product in Model)
            {
                @if (product.IsAvailable)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card h-100 border-1 shadow-sm" style="border-color: #e6a1c2 !important;">
                            <!-- Imagem do Produto -->
                            <div class="position-relative overflow-hidden" style="height: 300px; background: #f6f6f7;">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="~/@product.ImageUrl" alt="@product.Title" class="card-img-top img-fluid" style="object-fit: cover; width: 100%; height: 100%;" />
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center h-100">
                                        <i class="bi bi-image" style="font-size: 3rem; color: #ccc;"></i>
                                    </div>
                                }

                                <!-- Badge de Categoria -->
                                <div class="position-absolute top-0 end-0 m-3">
                                    <span class="badge rounded-pill px-3 py-2" style="background: #fce4ec; color: #e64e96; font-weight: 600;">
                                        @product.CategoryEnum
                                    </span>
                                </div>
                            </div>

                            <!-- Card Body -->
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title fw-bold" style="color: #343a40; line-height: 1.4;">
                                    @product.Title
                                </h5>

                                @if (!string.IsNullOrEmpty(product.Description))
                                {
                                    <p class="card-text text-muted small flex-grow-1">
                                        @product.Description
                                    </p>
                                }

                                <!-- Preço e Botão -->
                                <div class="d-flex align-items-end justify-content-between mt-3">
                                    <div>
                                        <p class="mb-0 small text-muted">Preço</p>
                                        <h4 class="mb-0 fw-bold" style="color: #e64e96;">
                                            R$ @product.Price.ToString("F2")
                                        </h4>
                                    </div>
                                    <button class="btn btn-sm" style="background: #e64e96; color: white; border: none;" data-bs-toggle="modal" data-bs-target="#productModal" 
                                            data-id="@product.Id"
                                            data-title="@product.Title"
                                            data-category="@product.CategoryEnum"
                                            data-price="@product.Price.ToString("F2")"
                                            data-description="@product.Description"
                                            data-image="@product.ImageUrl">
                                        <i class="bi bi-eye"></i> Ver
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center" role="alert">
            <i class="bi bi-info-circle"></i> Nenhum produto disponível no momento.
        </div>
    }
</div>

<style>
    .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 24px rgba(230, 78, 150, 0.15) !important;
    }

    .card-body {
        padding: 1.5rem;
    }

    @@media (max-width: 767.98px) {
        .display-5 {
            font-size: 2rem;
        }
    }
</style>

<!-- Modal do Produto -->
<div class="modal fade" id="productModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content" style="border: none; border-radius: 0;">
            <div class="modal-body p-0">
                <div class="row g-0 h-100">
                    <!-- Imagem à Esquerda -->
                    <div class="col-md-6 d-flex align-items-center justify-content-center overflow-hidden" style="background: #f6f6f7; min-height: 500px;">
                        <img id="modalProductImage" src="" alt="" class="img-fluid" style="width: 100%; height: 100%; object-fit: cover;" />
                    </div>

                    <!-- Detalhes à Direita -->
                    <div class="col-md-6 p-5" style="background: #2c3e50; color: #fff;">
                        <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>

                        <!-- Título -->
                        <h2 id="modalProductTitle" class="fw-bold mb-2"></h2>
                        <h2 id="modalJewelryCode" class="fw-bold mb-2"></h2>

                        <!-- Categoria -->
                        <div class="d-flex align-items-center gap-2 mb-4">
                            <span class="badge rounded-pill px-3 py-2" style="background: #fce4ec; color: #e64e96; font-weight: 600;" id="modalProductCategory"></span>
                            <span class="badge rounded-pill px-3 py-2" style="background: #fce4ec; color: #e64e96; font-weight: 600;" id="modalIsLastUnits"></span>
                        </div>

                        <!-- Descrição -->
                        <p id="modalProductDescription" class="text-light mb-4" style="line-height: 1.6; font-size: 0.95rem;"></p>

                        <!-- Preço em Destaque -->
                        <div class="mb-4">
                            <p class="text-muted small mb-1">Preço</p>
                            <h3 id="modalProductPrice" class="fw-bold" style="color: #e64e96; font-size: 2rem;">R$ 0,00</h3>
                        </div>                       

                        <!-- Botão de Ação -->
                        <button type="button" class="btn w-100" style="background: #e64e96; color: white; border: none; padding: 0.75rem; font-weight: 600; border-radius: 4px;">
                            <i class="bi bi-cart"></i> Adicionar ao Carrinho
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const productModal = document.getElementById('productModal');
        
        if (productModal) {
            productModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                
                // Pega os atributos data-* do botão
                const id = button.getAttribute('data-id');
                const title = button.getAttribute('data-title');
                const jewelryCode = button.getAttribute('data-jewelryCode');
                const category = button.getAttribute('data-category');
                const price = button.getAttribute('data-price');
                const description = button.getAttribute('data-description');
                const image = button.getAttribute('data-image');
                
                // Preenche o modal com os dados
                document.getElementById('modalProductTitle').textContent = title;
                document.getElementById('modalJewelryCode').textContent = jewelryCode;
                document.getElementById('modalProductCategory').textContent = category;
                document.getElementById('modalProductDescription').textContent = description || '';
                document.getElementById('modalProductPrice').textContent = 'R$ ' + price;
                document.getElementById('modalProductImage').src = image || '/images/placeholder.png';
                document.getElementById('modalProductImage').alt = title;
            });
        }
    });
</script>
