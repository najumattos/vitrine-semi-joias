@model VitrineSemiJoias.ViewModels.ProductViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Gerenciamento de Produtos | Novo Produto";
}
<div class="container-fluid px-4">
    <h2 class="mt-4">Cadastrar Nova Joia</h2>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-action="Index">Produtos</a></li>
        <li class="breadcrumb-item active">Novo Produto</li>
    </ol>

    <div class="card mb-4 shadow-sm">
        <div class="card-header">
            <i class="fas fa-plus me-1"></i> Preencha os detalhes do produto
        </div>
        <div class="card-body">
            <form asp-action="Edit" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImageUrl" />

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">T�tulo</label>
                            <input asp-for="Title" class="form-control" placeholder="Ex: Colar de P�rolas" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Descri��o</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label">Pre�o</label>
                                <div class="input-group">
                                    <span class="input-group-text">R$</span>
                                    <input asp-for="Price" class="form-control" />
                                </div>
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>                          
                        </div>

                        <div class="mb-3">
                            <label asp-for="CategoryEnum" class="form-label">Categoria</label>
                            <select asp-for="CategoryEnum" class="form-select"
                                    asp-items="Html.GetEnumSelectList<VitrineSemiJoias.Enums.CategoryEnum>()">
                                <option value="">-- Selecione --</option>
                            </select>
                            <span asp-validation-for="CategoryEnum" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Foto do Produto</label>
                            <input type="file"
                                   id="arquivoFoto"
                                   name="arquivoFoto"
                                   class="form-control"
                                   accept="image/*" />

                            <div class="form-text">Formatos aceitos: JPG, PNG, GIF, WebP (m�x. 5MB) - opcional.</div>

                            @{
                                var imagemAtual = string.IsNullOrEmpty(Model.ImageUrl)
                                ? string.Empty
                                : Url.Content("~/" + Model.ImageUrl.Replace("\\", "/").TrimStart('/'));
                            }

                            @if (!string.IsNullOrEmpty(imagemAtual))
                            {
                                <div class="mt-2">
                                    <small class="text-muted">Imagem atual:</small><br />
                                    <img src="@imagemAtual" alt="Imagem atual do produto" style="max-width: 150px; border: 1px solid #ddd;" />
                                </div>
                            }

                            <div id="fotoPreview" class="mt-3"></div>
                            <div id="fotoError" class="alert alert-danger mt-2" style="display:none;"></div>
                        </div>

                        <div class="mb-3 form-check form-switch">
                            <input class="form-check-input" type="checkbox" asp-for="IsAvailable" checked>
                            <label class="form-check-label" asp-for="IsAvailable">Dispon�vel para venda</label>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <input type="submit" value="Save" class="btn btn-primary" />
                </div>
            </form>
        </div>
    </div>
</div>

<div>
    <a asp-action="Index">Voltar para Lista</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const fileInput = document.getElementById('arquivoFoto');
            const previewDiv = document.getElementById('fotoPreview');
            const errorDiv = document.getElementById('fotoError');
            const form = document.querySelector('form');

            const MAX_FILE_SIZE = 5 * 1024 * 1024;
            const ALLOWED_TYPES = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];

            if (!fileInput || !previewDiv || !errorDiv || !form) {
                return;
            }

            fileInput.addEventListener('change', function () {
                previewDiv.innerHTML = '';
                errorDiv.style.display = 'none';
                errorDiv.textContent = '';

                if (!fileInput.files || fileInput.files.length === 0) {
                    return;
                }

                const file = fileInput.files[0];

                if (file.size > MAX_FILE_SIZE) {
                    errorDiv.textContent = 'Erro: Arquivo muito grande. Tamanho máximo: 5MB.';
                    errorDiv.style.display = 'block';
                    fileInput.value = '';
                    return;
                }

                if (!ALLOWED_TYPES.includes(file.type)) {
                    errorDiv.textContent = 'Erro: Tipo de arquivo não permitido. Use JPG, PNG, GIF ou WebP.';
                    errorDiv.style.display = 'block';
                    fileInput.value = '';
                    return;
                }

                const reader = new FileReader();
                reader.onload = function (event) {
                    const img = document.createElement('img');
                    img.src = event.target.result;
                    img.alt = 'Preview da nova foto';
                    img.style.maxWidth = '200px';
                    img.style.maxHeight = '200px';
                    img.style.borderRadius = '4px';
                    img.style.border = '1px solid #ddd';
                    img.style.padding = '4px';

                    previewDiv.appendChild(img);
                };
                reader.readAsDataURL(file);
            });

            form.addEventListener('submit', function (e) {
                if (fileInput.files.length === 0) {
                    return;
                }

                const file = fileInput.files[0];
                if (file.size > MAX_FILE_SIZE) {
                    e.preventDefault();
                    errorDiv.textContent = 'Erro: Arquivo muito grande. Tamanho máximo: 5MB.';
                    errorDiv.style.display = 'block';
                    return;
                }

                if (!ALLOWED_TYPES.includes(file.type)) {
                    e.preventDefault();
                    errorDiv.textContent = 'Erro: Tipo de arquivo não permitido.';
                    errorDiv.style.display = 'block';
                }
            });
        });
    </script>
}
