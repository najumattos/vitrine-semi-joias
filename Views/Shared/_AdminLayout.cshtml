@{
    var title = ViewData["Title"] ?? "Admin";
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root{
            --admin-bg: #f6f6f7;
            --admin-dark: #343a40;
            --admin-accent: #e6a1c2;
            --sidebar-width: 250px;
        }
        html,body{height:100%;}
        body{background:var(--admin-bg); margin:0; padding-top:56px;}
        .navbar-fixed-top{height:56px}

        /* Sidebar */
        .admin-sidebar{
            position:fixed;
            top:56px;
            left:0;
            width:var(--sidebar-width);
            height:calc(100vh - 56px);
            background:var(--admin-dark);
            color:#fff;
            padding:1rem 0.5rem;
            transition:transform .25s ease;
            z-index:1020;
        }
        .admin-sidebar .nav-link{color:rgba(255,255,255,0.85);}
        .admin-sidebar .nav-link:hover{color:#fff; background:rgba(255,255,255,0.03); border-radius:6px}
        .admin-sidebar .nav-link.active{background:var(--admin-accent); color:#000;}
        .admin-brand{padding:0 0.75rem; font-weight:600; letter-spacing:0.2px}

        /* Content */
        .admin-content{margin-left:var(--sidebar-width); padding:1.5rem; min-height:calc(100vh - 56px);}

        /* Responsive */
        @@media (max-width: 768px){
            .admin-sidebar{transform:translateX(-100%);} 
            .admin-sidebar.show{transform:translateX(0);} 
            .admin-content{margin-left:0; padding:1rem;}
            .navbar .sidebar-toggle{display:inline-block}
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-light bg-white border-bottom fixed-top d-flex align-items-center" style="height:56px">
        <div class="d-flex align-items-center px-2">
            <button class="btn btn-outline-secondary me-2 d-md-none sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar"><i class="bi bi-list"></i></button>
            <a class="navbar-brand mb-0 h1" href="#">Painel</a>
        </div>
        <div class="ms-auto d-flex align-items-center pe-3">
            <span class="me-3 text-muted small">Administrador</span>
        </div>
    </nav>

    <aside class="admin-sidebar" id="adminSidebar">
        <div class="admin-brand px-3 mb-3 text-white">Vitrine — Admin</div>
        <nav class="nav flex-column px-2">
            <a class="nav-link d-flex align-items-center mb-1" href="/">
                <i class="bi bi-speedometer2 me-2"></i>
                Dashboard
            </a>
            <a class="nav-link d-flex align-items-center mb-1" href="/Products">
                <i class="bi bi-box-seam me-2"></i>
                Produtos
            </a>
            <a class="nav-link d-flex align-items-center mb-1" href="/Gallery">
                <i class="bi bi-images me-2"></i>
                Galeria
            </a>
            <a class="nav-link d-flex align-items-center mb-1" href="/Banners">
                <i class="bi bi-image me-2"></i>
                Banners
            </a>
        </nav>
    </aside>

    <main class="admin-content">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="" crossorigin="anonymous"></script>
    <script>
        (function(){
            const sidebar = document.getElementById('adminSidebar');
            const toggle = document.getElementById('sidebarToggle');
            if(!toggle) return;
            toggle.addEventListener('click', function(){
                sidebar.classList.toggle('show');
            });
            // close when clicking outside on small screens
            document.addEventListener('click', function(e){
                if(window.innerWidth > 768) return;
                if(!sidebar.contains(e.target) && !toggle.contains(e.target)){
                    sidebar.classList.remove('show');
                }
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
