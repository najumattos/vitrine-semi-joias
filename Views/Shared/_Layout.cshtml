@using System.Linq
@using VitrineSemiJoias.Enums
@{
    var title = ViewData["Title"] ?? "Vitrine";
    var categories = Enum.GetValues(typeof(CategoryEnum)).Cast<CategoryEnum>();
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - Vitrine Semi Joias</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VitrineSemiJoias.styles.css" asp-append-version="true" />
    <style>
        :root{
            --bg-white:#ffffff;
            --dark-gray:#343a40;
            --pink-strong:#e64e96;
            --pink-light:#e6a1c2;
        }
        body{background:var(--bg-white); color:#222;}
        .navbar{background:var(--bg-white);}
        .brand-logo{font-weight:700; color:var(--dark-gray); font-size:1.5rem;}
        .nav-center .nav-link{color:var(--dark-gray); font-weight:500;}
        .nav-center .nav-link:hover{color:var(--pink-strong); text-decoration:underline}
        .btn-clientes{background:var(--pink-strong); color:#fff; border:none; font-weight:600}
        .btn-clientes:hover{background:var(--pink-light); color:#000}
        @@media (max-width: 767.98px){
            .nav-center{margin-top:.5rem; border-top:1px solid #eee; padding-top:.5rem}
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand brand-logo" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-gem"></i> Vitrine
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="d-flex">
                    <a class="btn btn-clientes btn-sm" asp-area="" asp-controller="Home" asp-action="Index">#UseCamilaReisSemiJoias</a>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container-fluid">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container">
            <p class="text-center py-3">&copy; 2026 - Vitrine Semi Joias — Joias e Acessórios</p>
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
