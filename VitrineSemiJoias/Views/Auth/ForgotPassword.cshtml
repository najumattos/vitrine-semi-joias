@model VitrineSemiJoias.ViewModels.ForgotPasswordViewModel

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Esqueci Minha Senha | Vitrine SemiJoias";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<h2 class="fs-5 fw-bold text-center text-dark mb-4">Esqueci Minha Senha</h2>

<form asp-action="ForgotPassword" asp-route-returnUrl="@returnUrl" method="post">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success d-flex align-items-center py-2 px-3 small mb-4 border-0 rounded-3" role="alert">
            <i class="bi bi-envelope-check-fill me-2 fs-5"></i>
            <div>
                @TempData["SuccessMessage"]
            </div>
        </div>
    }
    @Html.AntiForgeryToken()
    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 small mb-3 border-0 rounded-3"></div>
    }

    <div class="mb-3">
        <label asp-for="Email" class="form-label fw-semibold text-secondary small">E-mail</label>
        <div class="input-group">
            <span class="input-group-text bg-light text-muted border-end-0 rounded-start-3" style="font-size: 0.9rem;">
                <i class="bi bi-envelope"></i>
            </span>
            <input asp-for="Email" class="form-control border-start-0 rounded-end-3 py-2" placeholder="seu@email.com" autocomplete="email" />
        </div>
        <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
    </div>

    <button type="submit" class="btn btn-dark w-100 py-2 rounded-3 fw-semibold shadow-sm mb-2">
        <i class="bi bi-box-arrow-in-right me-2"></i>Redefinir Senha
    </button>

</form>