@model VitrineSemiJoias.ViewModels.LoginViewModel

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Acessar Sistema | Vitrine SemiJoias";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<h2 class="fs-5 fw-bold text-center text-dark mb-4">Acessar Sistema</h2>

<form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post">
    @Html.AntiForgeryToken()

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success d-flex align-items-center py-2 px-3 small mb-3 border-0 rounded-3" role="alert">
            <i class="bi bi-check-circle-fill me-2 fs-5"></i>
            <div>
                @TempData["SuccessMessage"]
            </div>
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 small mb-3 border-0 rounded-3"></div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label fw-semibold text-secondary small">E-mail comercial</label>
        <div class="input-group">
            <span class="input-group-text bg-light text-muted border-end-0 rounded-start-3" style="font-size: 0.9rem;">
                <i class="bi bi-envelope"></i>
            </span>
            <input asp-for="Email" class="form-control border-start-0 rounded-end-3 py-2" placeholder="seu@email.com" autocomplete="email" />
        </div>
        <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
    </div>

    <div class="mb-4">
        <label asp-for="Password" class="form-label fw-semibold text-secondary small">Senha de acesso</label>
        <div class="input-group">
            <span class="input-group-text bg-light text-muted border-end-0 rounded-start-3" style="font-size: 0.9rem;">
                <i class="bi bi-lock"></i>
            </span>
            <input asp-for="Password" type="password" class="form-control border-start-0 border-end-0 rounded-0 py-2" placeholder="••••••••" autocomplete="current-password" />
            <button type="button" class="input-group-text bg-light text-muted border-start-0 rounded-end-3 toggle-password" data-target="Password" aria-label="Mostrar senha">
                <i class="bi bi-eye"></i>
            </button>
        </div>
        <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="form-check m-0">
            <input asp-for="IsPersistent" class="form-check-input" />
            <label asp-for="IsPersistent" class="form-check-label text-secondary small">Lembrar de mim</label>
        </div>
        <div>
            <a asp-controller="Auth" asp-action="ForgotPassword" class="text-decoration-none text-muted small fw-semibold">
                Esqueceu a senha?
            </a>
        </div>
    </div>

    <button type="submit" class="btn btn-dark w-100 py-2 rounded-3 fw-semibold shadow-sm mb-2">
        <i class="bi bi-box-arrow-in-right me-2"></i> Entrar
    </button>

</form>