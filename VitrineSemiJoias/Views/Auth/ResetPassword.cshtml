@model VitrineSemiJoias.ViewModels.ResetPasswordViewModel

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Redefinir Senha | Vitrine SemiJoias";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<h2 class="fs-5 fw-bold text-center text-dark mb-4">Redefinir Senha</h2>

<form asp-action="ResetPassword" asp-route-returnUrl="@returnUrl" method="post">
    @Html.AntiForgeryToken()

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger py-2 px-3 small mb-3 border-0 rounded-3"></div>
    }

    <input asp-for="Token" type="hidden" />

    <div class="mb-3">
        <label asp-for="Email" class="form-label fw-semibold text-secondary small">E-mail</label>
        <div class="input-group">
            <span class="input-group-text bg-light text-muted border-end-0 rounded-start-3" style="font-size: 0.9rem;">
                <i class="bi bi-envelope"></i>
            </span>
            <input asp-for="Email" class="form-control border-start-0 rounded-end-3 py-2" placeholder="seu@email.com" autocomplete="email" />
        </div>
        <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
    </div>

    <div class="mb-4">
        <label asp-for="NewPassword" class="form-label fw-semibold text-secondary small">Nova Senha</label>
        <div class="input-group">
            <span class="input-group-text bg-light text-muted border-end-0 rounded-start-3" style="font-size: 0.9rem;">
                <i class="bi bi-lock"></i>
            </span>
            <input asp-for="NewPassword" type="password" class="form-control border-start-0 border-end-0 rounded-0 py-2" placeholder="••••••••" autocomplete="current-password" />
            <button type="button" class="input-group-text bg-light text-muted border-start-0 rounded-end-3 toggle-password" data-target="NewPassword" aria-label="Mostrar senha">
                <i class="bi bi-eye"></i>
            </button>
        </div>
        <span asp-validation-for="NewPassword" class="text-danger small d-block mt-1"></span>
    </div>

    <div class="mb-4">
        <label asp-for="ConfirmPassword" class="form-label fw-semibold text-secondary small">Confirme a senha</label>
        <div class="input-group">
            <span class="input-group-text bg-light text-muted border-end-0 rounded-start-3" style="font-size: 0.9rem;">
                <i class="bi bi-lock"></i>
            </span>
            <input asp-for="ConfirmPassword" type="password" class="form-control border-start-0 border-end-0 rounded-0 py-2" placeholder="••••••••" autocomplete="current-password" />
            <button type="button" class="input-group-text bg-light text-muted border-start-0 rounded-end-3 toggle-password" data-target="ConfirmPassword" aria-label="Mostrar senha">
                <i class="bi bi-eye"></i>
            </button>
        </div>
        <span asp-validation-for="ConfirmPassword" class="text-danger small d-block mt-1"></span>
    </div>

    <button type="submit" class="btn btn-dark w-100 py-2 rounded-3 fw-semibold shadow-sm mb-2">
        <i class="bi bi-box-arrow-in-right me-2"></i> Redefinir Senha
    </button>
</form>