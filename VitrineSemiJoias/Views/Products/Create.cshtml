@model VitrineSemiJoias.ViewModels.ProductViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Gerenciamento de Produtos | Novo Produto";
}

<div class="container py-4">
    <div class="mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Produtos</a></li>
                <li class="breadcrumb-item active text-dark fw-semibold">Novo Produto</li>
            </ol>
        </nav>
        <h1 class="h3 fw-bold text-dark mb-1">Cadastrar Nova Joia</h1>
        <p class="text-muted small mb-0">Insira as informações básicas, preço e imagem para disponibilizar a peça no mostruário.</p>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-light border-bottom py-3">
            <div class="d-flex align-items-center gap-2 text-secondary fw-semibold">
                <i class="bi bi-plus-circle fs-5"></i>
                <span>Preencha os detalhes do produto</span>
            </div>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger p-3 small mb-4"></div>

                <div class="row g-4">
                    <div class="col-lg-7">
                        <div class="mb-3">
                            <label asp-for="JewelryCode" class="form-label fw-semibold text-secondary small">Código da Joia (SKU)</label>
                            <input asp-for="JewelryCode" class="form-control rounded-2 font-monospace" placeholder="Ex: AN-001, CO-102" />
                            <span asp-validation-for="JewelryCode" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-semibold text-secondary small">Título da Peça</label>
                            <input asp-for="Title" class="form-control rounded-2" placeholder="Ex: Colar de Pérolas Cravejado" />
                            <span asp-validation-for="Title" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center gap-2 mb-1">
                                <label asp-for="Description" class="form-label fw-semibold text-secondary small mb-0">Descrição Detalhada</label>
                                <button type="button" id="btnGerarDescricaoIA" class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-2">
                                    <i class="bi bi-stars"></i>
                                    <span>Gerar Descrição com IA</span>
                                    <span id="spinnerGerarDescricaoIA" class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="display:none;"></span>
                                </button>
                            </div>
                            <textarea asp-for="Description" class="form-control rounded-2" rows="5" placeholder="Descreva os materiais, banho, tamanho e diferenciais da peça..."></textarea>
                            <div id="descricaoIaFeedback" class="small mt-2" style="display:none;"></div>
                            <span asp-validation-for="Description" class="text-danger small d-block mt-1"></span>
                        </div>
                    </div>

                    <div class="col-lg-5">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label fw-semibold text-secondary small">Preço de Venda</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-muted border-end-0">R$</span>
                                    <input asp-for="Price" class="form-control rounded-end-2 border-start-0" placeholder="0,00" />
                                </div>
                                <span asp-validation-for="Price" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="CategoryEnum" class="form-label fw-semibold text-secondary small">Categoria</label>
                                <select asp-for="CategoryEnum" class="form-select rounded-2" asp-items="Html.GetEnumSelectList<VitrineSemiJoias.Enums.CategoryEnum>()">
                                    <option value="">-- Selecione --</option>
                                </select>
                                <span asp-validation-for="CategoryEnum" class="text-danger small d-block mt-1"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold text-secondary small">Foto do Produto</label>
                            <input type="file" id="arquivoFoto" name="arquivoFoto" class="form-control rounded-2 mb-1" accept="image/*" />
                            <div class="form-text text-muted">Formatos aceitos: JPG, PNG, GIF, WebP (máx. 5MB) - opcional.</div>

                            <div id="containerPreview" class="mt-3" style="display: none;">
                                <span class="d-block text-muted text-uppercase fw-bold mb-1" style="font-size: 10px;">Pré-visualização</span>
                                <div class="position-relative d-inline-block">
                                    <div id="fotoPreview" class="rounded border p-1 bg-white" style="width: 120px; height: 120px;"></div>
                                    <button type="button" id="btnRemoverFoto" class="btn btn-danger btn-sm rounded-circle position-absolute top-0 end-0 translate-middle shadow-sm d-none" aria-label="Remover foto" style="width: 1.75rem; height: 1.75rem; padding: 0; line-height: 1;">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </div>
                            </div>
                            
                            <div id="fotoError" class="alert alert-danger p-2 small mt-2" style="display:none;"></div>
                        </div>

                        <div class="card bg-light border-0 p-3 mb-4 rounded-3">
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox" asp-for="IsAvailable" checked>
                                <label class="form-check-label fw-semibold text-dark ms-2" asp-for="IsAvailable">Disponível para venda</label>
                            </div>
                            <div class="form-text text-muted ms-5 mt-0">Se ativado, o produto aparecerá imediatamente para os clientes após salvar.</div>
                        </div>
                    </div>
                </div>

                <hr class="text-muted my-4" />

                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-2 px-3">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-dark rounded-2 px-4 py-2 shadow-sm fw-semibold">
                        <i class="bi bi-check-circle me-1"></i> Salvar Produto
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const fileInput = document.getElementById('arquivoFoto');
            const previewDiv = document.getElementById('fotoPreview');
            const containerPreview = document.getElementById('containerPreview');
            const errorDiv = document.getElementById('fotoError');
            const form = document.querySelector('form');
            const btnGerarDescricaoIA = document.getElementById('btnGerarDescricaoIA');
            const spinnerGerarDescricaoIA = document.getElementById('spinnerGerarDescricaoIA');
            const descricaoTextarea = document.getElementById('Description');
            const descricaoIaFeedback = document.getElementById('descricaoIaFeedback');
            const btnRemoverFoto = document.getElementById('btnRemoverFoto');

            const MAX_FILE_SIZE = 5 * 1024 * 1024;
            const ALLOWED_TYPES = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];

            if (!fileInput || !previewDiv || !containerPreview || !errorDiv || !form || !btnGerarDescricaoIA || !spinnerGerarDescricaoIA || !descricaoTextarea || !descricaoIaFeedback || !btnRemoverFoto) return;

            function exibirFeedbackDescricao(mensagem, sucesso) {
                descricaoIaFeedback.textContent = mensagem;
                descricaoIaFeedback.className = sucesso ? 'small mt-2 text-success' : 'small mt-2 text-danger';
                descricaoIaFeedback.style.display = 'block';
            }

            fileInput.addEventListener('change', function () {
                previewDiv.innerHTML = '';
                errorDiv.style.display = 'none';
                errorDiv.textContent = '';
                containerPreview.style.display = 'none';
                btnRemoverFoto.classList.add('d-none');

                if (!fileInput.files || fileInput.files.length === 0) return;

                const file = fileInput.files[0];

                if (file.size > MAX_FILE_SIZE) {
                    errorDiv.textContent = `Erro: Arquivo muito grande. Tamanho máximo: 5MB. Arquivo selecionado: ${(file.size / 1024 / 1024).toFixed(2)}MB`;
                    errorDiv.style.display = 'block';
                    fileInput.value = '';
                    return;
                }

                if (!ALLOWED_TYPES.includes(file.type)) {
                    errorDiv.textContent = 'Erro: Tipo de arquivo não permitido. Use JPG, PNG, GIF ou WebP.';
                    errorDiv.style.display = 'block';
                    fileInput.value = '';
                    return;
                }

                const reader = new FileReader();
                reader.onload = function (event) {
                    const img = document.createElement('img');
                    img.src = event.target.result;
                    img.className = 'w-100 h-100 rounded';
                    img.style.objectFit = 'cover';

                    previewDiv.appendChild(img);
                    containerPreview.style.display = 'block';
                    btnRemoverFoto.classList.remove('d-none');
                };
                reader.readAsDataURL(file);
            });

            btnRemoverFoto.addEventListener('click', function () {
                fileInput.value = '';
                previewDiv.innerHTML = '';
                containerPreview.style.display = 'none';
                errorDiv.textContent = '';
                errorDiv.style.display = 'none';
                btnRemoverFoto.classList.add('d-none');
            });

            form.addEventListener('submit', function (e) {
                if (fileInput.files.length === 0) return;

                const file = fileInput.files[0];
                if (file.size > MAX_FILE_SIZE || !ALLOWED_TYPES.includes(file.type)) {
                    e.preventDefault();
                    errorDiv.textContent = 'Erro: Corrija os problemas com o arquivo de imagem antes de salvar.';
                    errorDiv.style.display = 'block';
                }
            });

            btnGerarDescricaoIA.addEventListener('click', async function () {
                descricaoIaFeedback.style.display = 'none';
                errorDiv.style.display = 'none';
                errorDiv.textContent = '';

                if (!fileInput.files || fileInput.files.length === 0) {
                    exibirFeedbackDescricao('Selecione uma imagem antes de gerar a descrição.', false);
                    return;
                }

                const file = fileInput.files[0];
                if (file.size > MAX_FILE_SIZE || !ALLOWED_TYPES.includes(file.type)) {
                    exibirFeedbackDescricao('A imagem selecionada é inválida. Use JPG, PNG, GIF ou WebP (até 5MB).', false);
                    return;
                }

                const formData = new FormData();
                formData.append('arquivoFoto', file);

                btnGerarDescricaoIA.disabled = true;
                spinnerGerarDescricaoIA.style.display = 'inline-block';

                try {
                    // Append antiforgery token (if present) so ASP.NET's ValidateAntiForgeryToken accepts the request
                    const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
                    if (tokenInput && tokenInput.value) {
                        formData.append('__RequestVerificationToken', tokenInput.value);
                    }

                    const response = await fetch('@Url.Action("GenerateDescription", "Products")', {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        credentials: 'same-origin'
                    });

                    const data = await response.json();

                    if (!response.ok || !data.success) {
                        const message = (data && data.message) ? data.message : 'Não foi possível gerar a descrição agora.';
                        exibirFeedbackDescricao(message, false);
                        return;
                    }

                    descricaoTextarea.value = data.description || '';
                    exibirFeedbackDescricao('Descrição gerada com sucesso.', true);
                } catch (error) {
                    exibirFeedbackDescricao('Erro de comunicação ao gerar a descrição. Tente novamente.', false);
                } finally {
                    btnGerarDescricaoIA.disabled = false;
                    spinnerGerarDescricaoIA.style.display = 'none';
                }
            });
        });
    </script>
}