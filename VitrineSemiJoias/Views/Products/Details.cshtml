@model VitrineSemiJoias.ViewModels.ProductViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Gerenciamento de Produtos | Detalhes do Produto";
}

<div class="container py-4">
    <div class="mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Produtos</a></li>
                <li class="breadcrumb-item active text-dark fw-semibold">Visualizar Detalhes</li>
            </ol>
        </nav>
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div class="d-flex align-items-center gap-3">
                <h1 class="h3 fw-bold text-dark mb-0">@Model.Title</h1>
                <span class="badge bg-dark font-monospace px-2 py-1.5" style="font-size: 0.85rem;">#@Model.JewelryCode</span>
            </div>
            
            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-2 px-3">
                    <i class="bi bi-arrow-left me-1"></i> Voltar
                </a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-dark btn-sm rounded-2 px-3 fw-semibold">
                    <i class="bi bi-pencil-square me-1"></i> Editar Peça
                </a>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-3 text-center p-3 h-100 bg-white d-flex align-items-center justify-content-center">
                @{
                    var imagemProduto = string.IsNullOrEmpty(Model.ImageUrl)
                        ? string.Empty
                        : Url.Content("~/" + Model.ImageUrl.Replace("\\", "/").TrimStart('/'));
                }

                @if (!string.IsNullOrEmpty(imagemProduto))
                {
                    <div class="w-100 p-2" style="max-width: 320px;">
                        <img src="@imagemProduto" alt="@Model.Title" class="img-fluid rounded shadow-sm border" style="object-fit: cover; max-height: 380px;" />
                    </div>
                }
                else
                {
                    <div class="py-5 text-center text-muted">
                        <i class="bi bi-image fs-1 d-block mb-2 text-black-50"></i>
                        <span class="small d-block fw-semibold">Nenhuma imagem vinculada</span>
                        <span class="text-muted" style="font-size: 11px;">Insira uma foto editando o produto.</span>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-3 h-100 bg-white">
                <div class="card-header bg-light border-bottom py-3">
                    <div class="d-flex align-items-center gap-2 text-secondary fw-semibold">
                        <i class="bi bi-info-circle fs-5"></i>
                        <span>Ficha Técnica Interna</span>
                    </div>
                </div>
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <span class="d-block text-muted text-uppercase fw-bold small-label mb-1">Categoria</span>
                            <div class="fs-6 fw-semibold text-dark p-2 bg-light rounded border border-dashed">
                                <i class="bi bi-tags me-1 text-secondary"></i> @Model.CategoryEnum
                            </div>
                        </div>

                        <div class="col-md-6">
                            <span class="d-block text-muted text-uppercase fw-bold small-label mb-1">Preço Atual</span>
                            <div class="fs-6 fw-bold text-success p-2 bg-light rounded border border-dashed">
                                <span>@Model.Price.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</span>
                            </div>
                        </div>

                        <div class="col-12">
                            <span class="d-block text-muted text-uppercase fw-bold small-label mb-1">Descrição Comercial</span>
                            <div class="text-secondary p-3 bg-light rounded border border-dashed style-description">
                                @if (!string.IsNullOrWhiteSpace(Model.Description))
                                {
                                    @Html.Raw(Model.Description.Replace("\n", "<br />"))
                                }
                                else
                                {
                                    <em class="text-muted small">Nenhuma descrição informada para esta semijoia.</em>
                                }
                            </div>
                        </div>

                        <div class="col-12">
                            <span class="d-block text-muted text-uppercase fw-bold small-label mb-2">Status de Visibilidade</span>
                            @if (Model.IsAvailable)
                            {
                                <div class="d-inline-flex align-items-center gap-2 px-3 py-2 rounded-pill bg-success-subtle text-success border border-success-subtle fw-semibold font-sm">
                                    <span class="spinner-grow spinner-grow-sm text-success" role="status" style="animation-duration: 1.5s;"></span>
                                    <span>Ativo — Visível no mostruário público</span>
                                </div>
                            }
                            else
                            {
                                <div class="d-inline-flex align-items-center gap-2 px-3 py-2 rounded-pill bg-danger-subtle text-danger border border-danger-subtle fw-semibold font-sm">
                                    <i class="bi bi-eye-slash-fill"></i>
                                    <span>Inativo — Ocultado para clientes</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .small-label { font-size: 0.7rem; letter-spacing: 0.5px; }
    .border-dashed { border-style: dashed !important; }
    .style-description { min-height: 120px; line-height: 1.6; font-size: 0.95rem; white-space: pre-line; }
    .font-sm { font-size: 0.85rem; }
</style>