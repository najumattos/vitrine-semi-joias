@model VitrineSemiJoias.ViewModels.ProductViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Gerenciamento de Produtos | Editar Produto";
}

<div class="container py-4">
    <div class="mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Produtos</a></li>
                <li class="breadcrumb-item active text-dark fw-semibold">Editar Produto</li>
            </ol>
        </nav>
        <div class="d-flex align-items-center gap-3">
            <h1 class="h3 fw-bold text-dark mb-0">Editar Detalhes da Joia</h1>
            <span class="badge bg-dark font-monospace px-2 py-1.5" style="font-size: 0.85rem;">#@Model.JewelryCode</span>
        </div>
        <p class="text-muted small mb-0 mt-1">Atualize as informações, preço ou substitua a imagem atual da peça no mostruario.</p>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-light border-bottom py-3">
            <div class="d-flex align-items-center gap-2 text-secondary fw-semibold">
                <i class="bi bi-pencil-square fs-5"></i>
                <span>Modifique os dados necessários abaixo</span>
            </div>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger p-3 small mb-4"></div>
                
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="JewelryCode" />
                <input type="hidden" asp-for="ImageUrl" />

                <div class="row g-4">
                    <div class="col-lg-7">
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-semibold text-secondary small">Título da Peça</label>
                            <input asp-for="Title" class="form-control rounded-2" placeholder="Ex: Colar de Pérolas Cravejado" />
                            <span asp-validation-for="Title" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold text-secondary small">Descrição Detalhada</label>
                            <textarea asp-for="Description" class="form-control rounded-2" rows="5" placeholder="Descreva os materiais, banho, tamanho e detalhes..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small d-block mt-1"></span>
                        </div>
                    </div>

                    <div class="col-lg-5">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label fw-semibold text-secondary small">Preço de Venda</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-muted border-end-0">R$</span>
                                    <input asp-for="Price" class="form-control rounded-end-2 border-start-0" placeholder="0,00" />
                                </div>
                                <span asp-validation-for="Price" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="CategoryEnum" class="form-label fw-semibold text-secondary small">Categoria</label>
                                <select asp-for="CategoryEnum" class="form-select rounded-2" asp-items="Html.GetEnumSelectList<VitrineSemiJoias.Enums.CategoryEnum>()">
                                    <option value="">-- Selecione --</option>
                                </select>
                                <span asp-validation-for="CategoryEnum" class="text-danger small d-block mt-1"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold text-secondary small">Substituir Foto do Produto</label>
                            <input type="file" id="arquivoFoto" name="arquivoFoto" class="form-control rounded-2 mb-1" accept="image/*" />
                            <div class="form-text text-muted">Deixe em branco se quiser manter a foto atual.</div>

                            <div class="d-flex gap-3 mt-3">
                                @{
                                    var imagemAtual = string.IsNullOrEmpty(Model?.ImageUrl)
                                        ? string.Empty
                                        : Url.Content("~/" + Model.ImageUrl.Replace("\\", "/").TrimStart('/'));
                                }

                                @if (!string.IsNullOrEmpty(imagemAtual))
                                {
                                    <div class="text-center">
                                        <span class="d-block text-muted text-uppercase fw-bold mb-1" style="font-size: 10px;">Foto Atual</span>
                                        <div class="rounded border p-1 bg-white" style="width: 100px; height: 100px;">
                                            <img src="@imagemAtual" alt="Imagem atual" class="w-100 h-100 rounded" style="object-fit: cover;" />
                                        </div>
                                    </div>
                                }

                                <div id="containerPreview" style="display: none;">
                                    <span class="d-block text-success text-uppercase fw-bold mb-1" style="font-size: 10px;">Nova Foto</span>
                                    <div id="fotoPreview" class="rounded border p-1 bg-white" style="width: 100px; height: 100px;"></div>
                                </div>
                            </div>
                            
                            <div id="fotoError" class="alert alert-danger p-2 small mt-2" style="display:none;"></div>
                        </div>

                        <div class="card bg-light border-0 p-3 mb-4 rounded-3">
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox" asp-for="IsAvailable">
                                <label class="form-check-label fw-semibold text-dark ms-2" asp-for="IsAvailable">Disponível para venda</label>
                            </div>
                            <div class="form-text text-muted ms-5 mt-0">Se desativado, o produto ficará oculto para os clientes.</div>
                        </div>
                    </div>
                </div>

                <hr class="text-muted my-4" />

                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-2 px-3">
                        <i class="bi bi-arrow-left me-1"></i> Cancelar
                    </a>
                    <button type="submit" class="btn btn-dark rounded-2 px-4 py-2 shadow-sm fw-semibold">
                        <i class="bi bi-arrow-clockwise me-1"></i> Atualizar Joia
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const fileInput = document.getElementById('arquivoFoto');
            const previewDiv = document.getElementById('fotoPreview');
            const containerPreview = document.getElementById('containerPreview');
            const errorDiv = document.getElementById('fotoError');

            const MAX_FILE_SIZE = 5 * 1024 * 1024;
            const ALLOWED_TYPES = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];

            if (!fileInput || !previewDiv || !containerPreview || !errorDiv) return;

            fileInput.addEventListener('change', function () {
                previewDiv.innerHTML = '';
                errorDiv.style.display = 'none';
                containerPreview.style.display = 'none';

                if (!fileInput.files || fileInput.files.length === 0) return;

                const file = fileInput.files[0];

                if (file.size > MAX_FILE_SIZE) {
                    errorDiv.textContent = 'Erro: Arquivo muito grande. Tamanho máximo permitido: 5MB.';
                    errorDiv.style.display = 'block';
                    fileInput.value = '';
                    return;
                }

                if (!ALLOWED_TYPES.includes(file.type)) {
                    errorDiv.textContent = 'Erro: Tipo de arquivo inválido. Use JPG, PNG, GIF ou WebP.';
                    errorDiv.style.display = 'block';
                    fileInput.value = '';
                    return;
                }

                const reader = new FileReader();
                reader.onload = function (event) {
                    const img = document.createElement('img');
                    img.src = event.target.result;
                    img.className = 'w-100 h-100 rounded';
                    img.style.objectFit = 'cover';

                    previewDiv.appendChild(img);
                    containerPreview.style.display = 'block';
                };
                reader.readAsDataURL(file);
            });
        });
    </script>
}