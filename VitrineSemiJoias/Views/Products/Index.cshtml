@model IEnumerable<VitrineSemiJoias.ViewModels.ProductViewModel>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Gerenciamento de Produtos | Todos Produtos";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1">Gerenciamento do Mostruario</h1>
            <p class="text-muted small mb-0">Visualize, adicione e controle o status do inventário de semijoias.</p>
        </div>
        <a asp-action="Create" class="btn btn-dark d-flex align-items-center gap-2 shadow-sm rounded-3 px-3 py-2">
            <i class="bi bi-plus-circle"></i>
            <span>Adicionar Novo Produto</span>
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-3 mb-4">
        <div class="card-body py-3">
            <form asp-action="Index" method="get" class="d-flex flex-wrap gap-2 align-items-center">
                <div class="flex-grow-1" style="min-width: 280px;">
                    <input type="text"
                           name="searchTerm"
                           value="@(ViewData["SearchTerm"] as string)"
                           class="form-control"
                           placeholder="Buscar por título ou código da joia" />
                </div>

                <button type="submit" class="btn btn-dark d-inline-flex align-items-center gap-2">
                    <i class="bi bi-search"></i>
                    <span>Buscar</span>
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2">
                    <span>Limpar</span>
                </a>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-uppercase fs-7 text-muted" style="letter-spacing: 0.5px;">
                        <tr>
                            <th class="ps-4" style="width: 100px;">Foto</th>
                            <th style="width: 150px;">Código da Joia</th>
                            <th>Título</th>
                            <th>Preço</th>
                            <th>Categoria</th>
                            <th>Disponibilidade</th>
                            <th class="text-end pe-4" style="width: 180px;">Ações</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="rounded-3 border overflow-hidden d-flex align-items-center justify-content-center bg-light" style="width: 54px; height: 54px;">
                                        @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                        {
                                            <img src="~/@item.ImageUrl" alt="@item.Title" class="w-100 h-100" style="object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <i class="bi bi-image text-muted fs-5"></i>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border font-monospace px-2 py-1">#@item.JewelryCode</span>
                                </td>
                                <td>
                                    <div class="fw-semibold text-dark">@item.Title</div>
                                </td>
                                <td class="fw-bold text-secondary">
                                    @item.Price.ToString("C2")
                                </td>
                                <td>
                                    <span class="text-muted small">@item.CategoryEnum.ToString()</span>
                                </td>
                                <td>
                                    @if (item.IsAvailable)
                                    {
                                        <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-2.5 py-1">Ativo</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-secondary-subtle text-secondary border border-secondary-subtle px-2.5 py-1">Inativo</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-inline-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary border-0" title="Editar">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary border-0" title="Detalhes">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger border-0" title="Excluir">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>